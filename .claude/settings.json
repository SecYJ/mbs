{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/scripts/post-edit-check.sh",
                        "timeout": 60,
                        "statusMessage": "Linting & typechecking edits..."
                    }
                ]
            }
        ]
    }
}
